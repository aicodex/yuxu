# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/
env/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Project runtime data (should live in user's project dir, not in yuxu itself)
data/
config/secrets/
*.log

# Demo runners under examples/ create `_*_run_local/` scratch dirs with real
# API keys / checkpoints at runtime — never commit those.
examples/_*_run_local/

# Demo agents write generated artifacts into their own reports/ dirs at
# runtime; those are transient outputs, not source.
examples/*/reports/
